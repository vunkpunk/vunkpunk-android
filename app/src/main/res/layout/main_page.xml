<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <include layout="@layout/toolbar" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">


            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/tags_constraint_layout"
                android:layout_width="401dp"
                android:layout_height="wrap_content"
                app:layout_constraintStart_toStartOf="parent"
                android:padding="20dp">

                <androidx.constraintlayout.helper.widget.Flow
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:constraint_referenced_ids="tag_1,tag_2,tag_3,tag_4,add_tag"
                    app:flow_wrapMode="aligned"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <Button
                    android:id="@+id/tag_1"
                    android:layout_width="wrap_content"
                    android:layout_height="50dp"
                    android:drawableEnd="@drawable/tag_baseline_close_24"
                    android:text="@string/tag_1" />

                <Button
                    android:id="@+id/tag_2"
                    android:layout_width="wrap_content"
                    android:layout_height="50dp"
                    android:drawableEnd="@drawable/tag_baseline_close_24"
                    android:text="@string/tag_2" />

                <Button
                    android:id="@+id/tag_3"
                    android:layout_width="wrap_content"
                    android:layout_height="50dp"
                    android:drawableEnd="@drawable/tag_baseline_close_24"
                    android:text="@string/tag_3" />

                <Button
                    android:id="@+id/tag_4"
                    android:layout_width="wrap_content"
                    android:layout_height="50dp"
                    android:drawableEnd="@drawable/tag_baseline_close_24"
                    android:text="@string/tag_4" />

                <Button
                    android:id="@+id/add_tag"
                    android:layout_width="60dp"
                    android:layout_height="50dp"
                    android:text="@string/add_tag" />


            </androidx.constraintlayout.widget.ConstraintLayout>

            <GridView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:id="@+id/grid_view_cards"
                android:numColumns="2"
                android:layout_margin="20dp"
                android:gravity="center"
                android:horizontalSpacing="20dp"
                android:verticalSpacing="20dp"/>

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>